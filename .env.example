# Paste the contents of your Firebase service account JSON here, as ONE LINE.
# Get this from: Firebase Console -> Project Settings -> Service accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"PASTE_YOUR_OWN_FILE_CONTENTS_HERE"}

# Port the server listens on (most hosts override this automatically)
PORT=3000

# A shared secret admin devices use to register (simple protection, not full auth)
ADMIN_REGISTER_CODE=change-me-school-code
